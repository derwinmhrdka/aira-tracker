# Host nginx — separate from teknodika.com / airafin.teknodika.com
# Docker app listens on 127.0.0.1:13082 only.
#
# Setup on VPS (once):
#   1. DNS: aira.teknodika.com → VPS IP
#   2. sudo cp deploy/nginx-aira.conf.example /etc/nginx/sites-available/aira
#   3. sudo ln -s /etc/nginx/sites-available/aira /etc/nginx/sites-enabled/
#   4. sudo nginx -t && sudo systemctl reload nginx
#   5. sudo certbot --nginx -d aira.teknodika.com
#
# Deploy app: bash deploy/docker-deploy.sh
#
# Optional: redirect public IP:3082 → aira domain (replace VPS_PUBLIC_IP).

server {
    listen VPS_PUBLIC_IP:3082;
    server_name _;

    return 301 https://aira.teknodika.com$request_uri;
}

server {
    listen 80;
    server_name aira.teknodika.com;

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name aira.teknodika.com;

    # certbot adds ssl_certificate / ssl_certificate_key here

    client_max_body_size 3M;

    location / {
        proxy_pass http://127.0.0.1:13082;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 60s;
    }
}
