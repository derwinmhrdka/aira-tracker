# Baby Tracker — production environment (VPS / Docker)
# Copy: cp .env.example .env

# Public URL
DOMAIN=aira.teknodika.com
APP_URL=https://aira.teknodika.com

# PostgreSQL (Docker service `db`)
POSTGRES_USER=baby_tracker
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=baby_tracker
DATABASE_URL=postgresql://baby_tracker:change-me-strong-password@db:5432/baby_tracker

# iron-session — MUST be at least 32 characters
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars-long

# Initial PIN for first-time seed (4-6 digits)
INITIAL_PIN=1234
APP_PIN=1234

NODE_ENV=production
PORT=3000

# Web Push (generate: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@teknodika.com

# Cron secret for /api/push/cron (random string, min 32 chars)
CRON_SECRET=
